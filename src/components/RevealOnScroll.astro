---
// 板块滚动入场动效（渐进增强）
// 所有 <section> 初始 opacity:0，进入视口后加 .is-visible 触发淡入上滑。
// 不支持 IntersectionObserver / 禁用 JS 时，<noscript> 兜底保持可见。
---

<style is:global>
  /* 仅在支持 JS 时启用初始隐藏——noscript 里会覆盖 */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 600ms ease,
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* 尊重"减少动效"系统偏好：直接显示，不做位移 */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<noscript>
  <style>
    /* 无 JS 时移除隐藏，保证内容可见 */
    .reveal {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  const sections = document.querySelectorAll('section')
  // 没有内容或不支持观察器时直接显示，保证可访问
  if (!('IntersectionObserver' in window)) {
    sections.forEach((s) => s.classList.add('is-visible'))
  } else {
    sections.forEach((s) => s.classList.add('reveal'))
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
            obs.unobserve(entry.target) // 只触发一次
          }
        })
      },
      { threshold: 0.1, rootMargin: '0px 0px -10% 0px' }
    )
    sections.forEach((s) => observer.observe(s))
  }
</script>
