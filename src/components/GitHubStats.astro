---
// ============================================================
// GitHubStats.astro —— 统计面板外壳
// 数据由 GitHubStats.vue（client:load）在浏览器端拉取 + localStorage 缓存。
// 缓存策略：每天 0 点 / 12 点后第一次访问才拉新，其余读缓存，失败静默兜底。
// 文案（含 since 模板）由这里拼好传进 Vue，保持 i18n。
// ============================================================
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import { username } from '../data/profile'
import GitHubStatsVue from './GitHubStats.vue'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const labels = {
  repos: t('stats.label.repos'),
  stars: t('stats.label.stars'),
  followers: t('stats.label.followers'),
  forks: t('stats.label.forks'),
  sinceTemplate: t('stats.since'), // 含 {since} {years} 占位
  sinceFallback: `GitHub {since}`, // years=0 时简化
  langDist: t('stats.langDist'),
}
---

<section class="stats container" id="stats">
  <h2 class="section-title">{t('stats.title')}</h2>
  <GitHubStatsVue client:load username={username} labels={labels} />
</section>

<style lang="scss">
.stats {
  padding: var(--space-8) var(--space-3);
}

.section-title {
  font-size: var(--font-h1);
  font-weight: 700;
  margin-bottom: var(--space-4);
}
</style>
